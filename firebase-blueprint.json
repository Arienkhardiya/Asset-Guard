{
  "entities": {
    "User": {
      "title": "User",
      "description": "Enterprise user profile and role definition with tenant awareness",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Cybersecurity Analyst", "Legal Analyst", "Business Analyst", "Creator"] },
        "tenantType": { "type": "string", "enum": ["Organization", "Creator"] },
        "tenantId": { "type": "string" },
        "tenantName": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "role", "tenantType", "tenantId", "tenantName", "createdAt", "updatedAt"]
    },
    "Scan": {
      "title": "Scan",
      "description": "Output of the pipeline scanner, bound to a specific tenant",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "createdBy": { "type": "string" },
        "inputQuery": { "type": "string" },
        "riskLevel": { "type": "string" },
        "similarity": { "type": "number" },
        "confidence": { "type": "string" },
        "spreadLevel": { "type": "string" },
        "totalLinks": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["tenantId", "createdBy", "inputQuery", "riskLevel", "similarity", "confidence", "spreadLevel", "totalLinks", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "System-wide immutable trail of security-relevant user actions",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "role": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["tenantId", "userId", "userEmail", "role", "action", "details", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Enterprise user accounts with roles for RBAC and multi-tenancy"
    },
    "/scans/{scanId}": {
      "schema": { "$ref": "#/entities/Scan" },
      "description": "Scan intelligence records strictly isolated by tenant ID"
    },
    "/audit_logs/{logId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "Enterprise audit logs with row-level security for analysts and administrators"
    }
  }
}
